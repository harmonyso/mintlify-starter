{
    "name": "harmony-mintlify-docs",
    "pnpm": {
        "onlyBuiltDependencies": [
            "sharp"
        ]
    },
    "private": true,
    "type": "module",
    "scripts": {
        "screenshots:dashboard": "node guides/_utilities/screenshots/capture-dashboard-screenshots.mjs",
        "screenshots:dashboard:login": "pnpm exec playwright install chromium && node guides/_utilities/screenshots/capture-dashboard-screenshots.mjs --login",
        "screenshots:dashboard:run": "pnpm exec playwright install chromium && pnpm run screenshots:dashboard",
        "video:article": "node guides/_utilities/video/capture-article-video.mjs",
        "video:narration": "AWS_PROFILE=harmony-mgmt AWS_REGION=us-east-1 node guides/_utilities/video/video-narration.mjs",
        "video:full": "node guides/_utilities/video/video-full.mjs"
    },
    "devDependencies": {
        "playwright": "^1.52.0"
    },
    "dependencies": {
        "sharp": "^0.33.0",
        "@aws-sdk/client-bedrock-runtime": "^3.700.0",
        "@aws-sdk/client-polly": "^3.700.0",
        "ghost-cursor-playwright": "^2.1.0",
        "@aws-sdk/credential-providers": "^3.700.0"
    }
}